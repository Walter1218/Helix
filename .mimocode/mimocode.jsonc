{
  "$schema": "https://opencode.ai/config.json",
  "provider": {},
  "permission": {
    "edit": {
      "packages/opencode/migration/*": "deny",
    },
  },
  "mcp": {},
  "memory": {
    "cc_index": true,
    "vector": {
      "enabled": true
    }
  },
  "dream": {
    "auto": true,
    "interval_days": 1
  },
  "distill": {
    "auto": true,
    "interval_days": 30
  },
}
