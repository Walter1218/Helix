{
  "$schema": "https://opencode.ai/config.json",
  "_comment": "复制此文件到 ~/.config/mimocode/mimocode.json 并按需修改。所有 API Key 建议使用 ${ENV_VAR} 语法引用环境变量。",

  "model": "xiaomi/mimo-v2.5-pro",

  "agent": {
    "build": {
      "model": "xiaomi/mimo-v2.5-pro"
    }
  },

  "provider": {
    "xiaomi": {
      "name": "MiMo",
      "npm": "@ai-sdk/openai-compatible",
      "env": ["MIMO_API_KEY"],
      "options": {
        "apiKey": "${MIMO_API_KEY}",
        "baseURL": "https://api.xiaomimimo.com/v1"
      },
      "models": {
        "mimo-v2.5-pro": {
          "name": "MiMo V2.5 Pro",
          "tool_call": true,
          "reasoning": true,
          "temperature": true,
          "limit": { "context": 1000000, "output": 128000 }
        },
        "mimo-v2.5": {
          "name": "MiMo V2.5",
          "tool_call": true,
          "reasoning": true,
          "temperature": true,
          "limit": { "context": 1000000, "output": 128000 }
        }
      }
    }

    // 以下为第三方模型配置示例，取消注释即可启用。
    // 更多 provider 配置参考 docs/USAGE.md §2.1

    // "deepseek": {
