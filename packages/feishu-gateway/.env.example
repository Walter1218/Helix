# ===========================
# 飞书应用凭证（必填）
# 在飞书开放平台 → 你的应用 → 凭证与基础信息 中获取
# ===========================
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=your_app_secret_here

# 飞书域名：feishu（国内）或 lark（海外）
FEISHU_DOMAIN=feishu

# ===========================
# 安全策略（可选）
# ===========================
# 用户白名单：只允许这些 open_id 使用，逗号分隔，留空则所有人可用
FEISHU_ALLOWED_USERS=

# 群聊响应模式：mention（需@才响应）/ always（所有消息都响应）/ off（不响应群聊）
FEISHU_GROUP_MODE=mention

# ===========================
# Helix 引擎配置
# ===========================
# Helix HTTP 服务地址（mimo serve 的监听地址）
HELIX_URL=http://localhost:3000

# Helix 工作目录（Agent 在此目录执行任务）
# HELIX_WORK_DIR=/path/to/your/project

# mimo serve 的认证密码（如果设置了 MIMOCODE_SERVER_PASSWORD）
# MIMOCODE_SERVER_PASSWORD=your_password_here

# 默认模型
HELIX_MODEL_PROVIDER=mimo
HELIX_MODEL=mimo-v2.5-pro

# ===========================
# 启动说明
# ===========================
# 1. 先启动 mimo serve:
#    MIMOCODE_SERVER_PASSWORD=xxx mimo serve --port 3000
#
# 2. 再启动飞书 Gateway:
#    cd packages/feishu-gateway && bun run src/index.ts
