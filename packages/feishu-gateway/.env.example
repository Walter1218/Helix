# 飞书 App 凭证（在 open.feishu.cn 创建企业自建应用后获取）
FEISHU_APP_ID=cli_xxxxxxxxxxxxx
FEISHU_APP_SECRET=your_app_secret_here

# feishu=飞书国内版 / lark=Lark 国际版
FEISHU_DOMAIN=feishu

# Helix 服务地址（mimo server 启动后监听）
HELIX_URL=http://localhost:3000

# 用户任务默认执行目录（飞书用户下发任务时，Agent 在这个目录中工作）
HELIX_WORK_DIR=/Users/onetwo/Documents/trae_projects/Helix

# 默认模型
HELIX_MODEL_PROVIDER=mimo
HELIX_MODEL=mimo-v2.5-pro

# 可选：用户白名单（留空允许所有人）
FEISHU_ALLOWED_USERS=

# 可选：群聊响应模式 mention=仅@机器人 always=全部消息 off=不响应群聊
FEISHU_GROUP_MODE=mention
