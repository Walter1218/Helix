{
  "$schema": "https://opencode.ai/theme.json",
  "defs": {
    "hxBg0": "#060614",
    "hxBg1": "#0c0c20",
    "hxBg2": "#12122a",
    "hxBg3": "#1a1a36",
    "hxCyan": "#00ffcc",
    "hxCyanDim": "#00ccaa",
    "hxCyanHi": "#66ffdd",
    "hxMagenta": "#ff00cc",
    "hxMagentaDim": "#cc00aa",
    "hxGold": "#ffcc00",
    "hxText": "#d0d0ff",
    "hxTextDim": "#6666aa",
    "hxTextHi": "#f0f0ff",
    "hxRed": "#ff4466",
    "hxGreen": "#00ff88",
    "hxOrange": "#ff8844",
    "hxBorder": "#1a1a40",
    "hxBorderHi": "#333366",
    "lightBg": "#f5f0ff",
    "lightPanel": "#ede4f8",
    "lightElement": "#e4d9f2",
    "lightCyan": "#009977",
    "lightMagenta": "#990077",
    "lightGold": "#aa8800",
    "lightText": "#1a1040",
    "lightGray": "#8877aa"
  },
  "theme": {
    "primary": { "dark": "hxCyan", "light": "lightCyan" },
    "secondary": { "dark": "hxMagenta", "light": "lightMagenta" },
    "accent": { "dark": "hxGold", "light": "lightGold" },
    "error": { "dark": "hxRed", "light": "hxRed" },
    "warning": { "dark": "hxOrange", "light": "hxOrange" },
    "success": { "dark": "hxGreen", "light": "hxGreen" },
    "info": { "dark": "hxCyanDim", "light": "lightCyan" },
    "text": { "dark": "hxText", "light": "lightText" },
    "textMuted": { "dark": "hxTextDim", "light": "lightGray" },
    "background": { "dark": "hxBg0", "light": "lightBg" },
    "backgroundPanel": { "dark": "hxBg1", "light": "lightPanel" },
    "backgroundElement": { "dark": "hxBg2", "light": "lightElement" },
    "border": { "dark": "hxBorder", "light": "lightGray" },
    "borderActive": { "dark": "hxBorderHi", "light": "lightGray" },
    "borderSubtle": { "dark": "hxBg3", "light": "lightElement" },
    "diffAdded": { "dark": "hxGreen", "light": "hxGreen" },
    "diffRemoved": { "dark": "hxRed", "light": "hxRed" },
    "diffContext": { "dark": "hxTextDim", "light": "lightGray" },
    "diffHunkHeader": { "dark": "hxCyanDim", "light": "lightCyan" },
    "diffHighlightAdded": { "dark": "#77ffbb", "light": "#44cc77" },
    "diffHighlightRemoved": { "dark": "#ff7788", "light": "#ff4466" },
    "diffAddedBg": { "dark": "#0a1a14", "light": "#d5f0e5" },
    "diffRemovedBg": { "dark": "#1a0a10", "light": "#f5d8e0" },
    "diffContextBg": { "dark": "hxBg1", "light": "lightPanel" },
    "diffLineNumber": { "dark": "textMuted", "light": "#7766a0" },
    "diffAddedLineNumberBg": { "dark": "#0d140e", "light": "#c8e5d8" },
    "diffRemovedLineNumberBg": { "dark": "#140a0e", "light": "#eec8d2" },
    "markdownText": { "dark": "hxText", "light": "lightText" },
    "markdownHeading": { "dark": "hxCyan", "light": "lightCyan" },
    "markdownLink": { "dark": "hxMagenta", "light": "lightMagenta" },
    "markdownLinkText": { "dark": "hxCyanDim", "light": "lightCyan" },
    "markdownCode": { "dark": "hxGreen", "light": "hxGreen" },
    "markdownBlockQuote": { "dark": "hxTextDim", "light": "lightGray" },
    "markdownEmph": { "dark": "hxGold", "light": "lightGold" },
    "markdownStrong": { "dark": "hxOrange", "light": "hxOrange" },
    "markdownHorizontalRule": { "dark": "hxTextDim", "light": "lightGray" },
    "markdownListItem": { "dark": "hxCyan", "light": "lightCyan" },
    "markdownListEnumeration": { "dark": "hxCyanDim", "light": "lightCyan" },
    "markdownImage": { "dark": "hxCyan", "light": "lightCyan" },
    "markdownImageText": { "dark": "hxCyanDim", "light": "lightCyan" },
    "markdownCodeBlock": { "dark": "hxText", "light": "lightText" },
    "syntaxComment": { "dark": "hxTextDim", "light": "lightGray" },
    "syntaxKeyword": { "dark": "hxMagenta", "light": "lightMagenta" },
    "syntaxFunction": { "dark": "hxCyan", "light": "lightCyan" },
    "syntaxVariable": { "dark": "hxText", "light": "lightText" },
    "syntaxString": { "dark": "hxGreen", "light": "hxGreen" },
    "syntaxNumber": { "dark": "hxOrange", "light": "hxOrange" },
    "syntaxType": { "dark": "hxGold", "light": "lightGold" },
    "syntaxOperator": { "dark": "hxCyanDim", "light": "lightCyan" },
    "syntaxPunctuation": { "dark": "hxText", "light": "lightText" }
  }
}
